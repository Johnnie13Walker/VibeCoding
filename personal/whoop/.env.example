# Timezone
TZ=Europe/Moscow

# WHOOP OAuth
WHOOP_CLIENT_ID=
WHOOP_CLIENT_SECRET=
WHOOP_REDIRECT_URI=
WHOOP_API_BASE=https://api.prod.whoop.com/developer/v2
WHOOP_TOKEN_URL=https://api.prod.whoop.com/oauth/oauth2/token
WHOOP_REFRESH_TOKEN=

# Tracker storage
PROGRESS_DB_PATH=/Users/pro2kuror/.config/vibecoding/whoop/progress_tracker.sqlite3
WHOOP_TOKEN_CACHE_PATH=/Users/pro2kuror/.config/vibecoding/whoop/.whoop_tokens.json

# Metric model (A: only WHOOP metric)
# steps are not available in official WHOOP Developer API OpenAPI spec
PROGRESS_METRIC=kilojoule
PROGRESS_GOAL_DEFAULT=10000
PROGRESS_MAX_PINGS_PER_DAY=6
PROGRESS_PINGS_ENABLED=1

# Telegram (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# WHOOP Morning Brief redesign pilot
# false: отправляется старый morning report
# true: старый report, затем через 30 секунд новый brief на сверку
LARISA_WHOOP_PILOT=false
LARISA_WHOOP_PILOT_DELAY_SECONDS=30
WHOOP_STATE_FILE=/var/lib/cloudbot-larisa-whoop/whoop-state.json
