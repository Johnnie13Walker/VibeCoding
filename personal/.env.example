# Environment Configuration for Personal Workspace

# OpenAI Configuration (Personal Account)
OPENAI_API_KEY=your_personal_openai_key
OPENAI_ORGANIZATION=your_personal_org

# Personal APIs
NOTION_TOKEN=your_notion_integration_token
NOTION_DATABASE_ID=your_database_id

GITHUB_TOKEN=your_github_personal_access_token
GITHUB_USERNAME=your_github_username

# Twitter API (for experiments)
TWITTER_API_KEY=your_twitter_api_key
TWITTER_API_SECRET=your_twitter_api_secret
TWITTER_ACCESS_TOKEN=your_access_token
TWITTER_ACCESS_SECRET=your_access_secret

# Telegram Bot (Personal)
TELEGRAM_BOT_TOKEN=your_personal_bot_token

# Database (Local SQLite for experiments)
DATABASE_URL=sqlite:./personal.db

# Development
NODE_ENV=development
PORT=3001
LOG_LEVEL=debug

# Personal Services
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret

# Learning Platforms
UDEMY_API_KEY=your_udemy_api_key
COURSERA_API_KEY=your_coursera_api_key

# Personal Cloud
DROPBOX_ACCESS_TOKEN=your_dropbox_token
GOOGLE_DRIVE_CREDENTIALS=path/to/credentials.json

# Experiment Flags
ENABLE_EXPERIMENTS=true
ENABLE_DEBUG_MODE=true
ENABLE_MOCK_DATA=true

# Local Development
LOCAL_API_URL=http://localhost:3001
LOCAL_FRONTEND_URL=http://localhost:3000

# Personal Secrets (Keep Secure!)
ENCRYPTION_KEY=your_personal_encryption_key
JWT_SECRET=your_personal_jwt_secret

# Monitoring (Optional for personal)
SENTRY_DSN=https://your-personal-sentry-dsn@sentry.io/project-id

# Feature Flags
ENABLE_AI_ASSISTANT=true
ENABLE_VOICE_INTERFACE=false
ENABLE_MULTIMODAL_AI=false
