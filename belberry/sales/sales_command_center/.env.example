# PostgreSQL (общий для runner и web). Локально: docker postgres:16
DATABASE_URL=postgresql://scc:scc@localhost:5432/scc

# Bitrix24 OAuth: state-файл и общий sync-скрипт, не токены в env напрямую
BITRIX_STATE_PATH=/Users/pro2kuror/Desktop/VibeCoding/shared/config/bitrix24-state/install.latest.json
BITRIX_SYNC_SCRIPT=/Users/pro2kuror/Desktop/VibeCoding/shared/scripts/bitrix-sync-state.sh

# Anthropic (LLM-разбор, Фаза 3)
ANTHROPIC_API_KEY=sk-ant-xxxxx

# iron-session (Фаза 4): минимум 32 символа
SESSION_SECRET=change-me-min-32-chars-long-secret

# Telegram (Фаза 6)
TELEGRAM_BOT_TOKEN=123456:xxxxx
TELEGRAM_CHAT_ID=-100xxxxx
TELEGRAM_ALERT_CHAT_ID=-100xxxxx
SCC_BASE_URL=https://sales.example.com

# Часовой пояс runner
TZ=Europe/Moscow
