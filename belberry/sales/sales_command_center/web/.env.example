# Web использует те же server-only секреты, что и корневой .env.example.
# Не добавлять NEXT_PUBLIC_ для токенов, ключей, паролей и DSN.
DATABASE_URL=postgresql://scc:scc@localhost:5432/scc
SESSION_SECRET=change-me-min-32-chars-long-secret

# BITRIX_STATE_PATH must point at LARISA's OAuth state (Bitrix user 2812).
# im.notify.personal.add sends the login code FROM the token owner, so this token
# MUST belong to 2812 — otherwise managers receive the code from the wrong sender.
BITRIX_STATE_PATH=/Users/pro2kuror/Desktop/VibeCoding/shared/config/bitrix24-state/install.latest.json
# SESSION_SECRET must be at least 32 chars. Generate: openssl rand -base64 32
