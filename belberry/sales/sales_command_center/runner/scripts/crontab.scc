# Global Sales Dashboard — образец crontab для VPS.
# Перед установкой заменить /path/to/runner на абсолютный путь runner-каталога.
# Env (DATABASE_URL/SCC_*/TELEGRAM_*) задавать через окружение сервиса/обёртки на VPS.

TZ=Europe/Moscow

# Пн–Пт 08:00 МСК: сформировать отчёт за прошлый рабочий день.
0 8 * * 1-5 /path/to/runner/scripts/run_daily.sh

# Пн–Пт каждые 20 мин 08:00–22:00 МСК: лёгкий снимок «Сегодня» (live) +
# синк статусов/дедлайнов/ответственных автозадач из Bitrix (sync_task_statuses).
*/20 8-22 * * 1-5 /path/to/runner/scripts/run_live.sh

# ЕЖЕДНЕВНО каждые 20 мин (сдвиг 10/30/50, чтобы не совпасть с live), рабочие часы:
# refresh данных за сегодня для дашбордов/вкладок (сделки/звонки/встречи/активность
# + причины отвала + названия сделок), БЕЗ LLM. Веб читает Postgres на каждый запрос
# → /dashboard, /telemarketing, список встреч актуальны каждые 20 мин.
# (Часы в UTC, как у остального cron этого сервера: 6-17 UTC = 09:00–20:59 МСК.)
10,30,50 6-17 * * * /path/to/runner/scripts/run_refresh.sh

# ЕЖЕДНЕВНО раз в час (:05), рабочие часы: инкрементальный LLM-разбор НОВЫХ встреч
# (только непроанализированные; ловит поздние транскрипты, не гоняет готовые).
5 6-17 * * * /path/to/runner/scripts/run_analyze_pending.sh

# Пн–Пт раз в час 09:00–20:00 МСК: тяжёлый проход Wazzup-чатов «Сегодня».
0 9-20 * * 1-5 /path/to/runner/scripts/run_live_wazzup.sh

# КАЖДЫЕ 2 ЧАСА 09:00–23:00 МСК: дозачёт «итоги встречи отправлены» по пост-встречной
# переписке (Wazzup после встречи). Итоги, отправленные после разбора встречи,
# засчитываются в течение ~2 ч; окно 7 дней, идемпотентно. Балл +1 (потолок 10).
0 9-23/2 * * * /path/to/runner/scripts/run_backfill_summaries.sh

# Ежедневно 03:00 МСК: Postgres backup + ротация.
0 3 * * * /path/to/runner/scripts/backup_postgres.sh

# КАЖДУЮ МИНУТУ 24/7: воркер аудита сделок (страница /audit). Аудит идёт фоном
# независимо от того, открыта ли вкладка; веб ещё и пинает воркер сразу при запуске.
# Дёшев при отсутствии заданий (один SELECT); flock от наложения прогонов.
* * * * * /path/to/runner/scripts/run_audit_worker.sh

# ЕЖЕДНЕВНО 08:00 МСК (Пн–Пт): радар застрявших сделок → авто-аудиты (дедуп 30д, лимит 10).
0 5 * * 1-5 /path/to/runner/scripts/run_audit_radar.sh

# ЕЖЕДНЕВНО 08:15 МСК (Пн–Пт): петля отслеживания возврата — сработал ли возврат через N дней.
15 5 * * 1-5 /path/to/runner/scripts/run_audit_followup.sh

# ЕЖЕДНЕВНО 08:30 МСК (Пн–Пт): превентив — живые сделки с риск-флагами → блок «Риск процесса» в Алертах.
30 5 * * 1-5 /path/to/runner/scripts/run_audit_preventive.sh
