# Belberry Portfolio Sync — env переменные
# Скопируй в .env (или загрузи через `set -a; source .env; set +a`) и переопредели нужное.
# Все имеют разумные дефолты — без файла .env скрипт тоже работает.

# === Источник и цели Google Sheets ===

# Мастер-таблица продаж (источник)
PORTFOLIO_SOURCE_SHEET_URL="https://docs.google.com/spreadsheets/d/17SBisFgKrf3hRP_zjVPC2e4wMzlq8j8HDC2bvkyS74Y/edit?gid=1482533080#gid=1482533080"

# Таблица "Клиенты" — основное портфолио для отдела продаж и КП
PORTFOLIO_CLIENTS_SHEET_URL="https://docs.google.com/spreadsheets/d/1TSEei_ncr3SQmiYT074Q17HOzmxxtrPV447j27N_BZw/edit?gid=1955270606#gid=1955270606"
PORTFOLIO_CLIENTS_SHEET_TITLE="Клиенты"

# Плоская база записей (для аналитики)
PORTFOLIO_DATABASE_SHEET_URL="https://docs.google.com/spreadsheets/d/1TgWlFHOvSDtW0e60fCLNvWDW7ADwOimHpypbQG7GI9E/edit"

# Визуальный дашборд (вкладки: Дашборд, Категории, Продукты, Клиенты, Продукт × Клиент, Классификация, dash_data)
PORTFOLIO_DASHBOARD_SHEET_URL="https://docs.google.com/spreadsheets/d/1om_oGYvDZrADYbAbznZOyk7InhHF7kKs5MrMzzAJC2A/edit"

# === Google Service Account ===

# JSON-ключ сервис-аккаунта finance-director-sheets с правами read+write
# на все три таблицы выше.
PORTFOLIO_GOOGLE_SERVICE_ACCOUNT_JSON="/Users/pro2kuror/.config/vibecoding/assistant/secrets/finance-director-sheets-903611b799c3.json"

# === Отбивка в Telegram ===

# 1 = слать отбивку Ларисе Ивановне после успешного синка, 0 = молча
PORTFOLIO_CLIENTS_SEND_TELEGRAM=1

# Токен бота Ларисы и chat_id — см. reference-larisa-ivanovna-bot в memory
# LARISA_TELEGRAM_BOT_TOKEN=
# LARISA_TELEGRAM_CHAT_ID=

# Dry-run отбивку (вывод в файл вместо реальной отправки)
# LARISA_TELEGRAM_DRY_RUN=1

# === Бизнес-правила (можно править) ===

# Проекты которые НЕ попадают в портфолио (через запятую)
PORTFOLIO_CLIENTS_EXCLUDE_PROJECTS="saturnia.ru"

# Сервисы которые НЕ попадают в портфолио (agency/service записи)
PORTFOLIO_CLIENTS_EXCLUDE_SERVICES="agency,service,services,эдженси,сервисес"

# === Куда писать отчёт и логи (если запускаешь не daily runner) ===

# PORTFOLIO_CLIENTS_REPORT_JSON="./logs/portfolio_clients_sync.latest.json"
# PORTFOLIO_CLIENTS_LOG_DIR="./logs"
