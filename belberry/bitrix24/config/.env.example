# Belberry Bitrix24 process config
# Реальный файл `.env` не коммитится.

# Google service account JSON.
# Локально можно использовать путь ниже, на сервере лучше хранить JSON вне repo.
BELBERRY_BITRIX24_GOOGLE_SERVICE_ACCOUNT_JSON=belberry/bitrix24/config/google-service-account.json

# Google Sheets / Drive IDs для рабочих отчётов и аудитов.
BELBERRY_BITRIX24_GOOGLE_AUDIT_SHEET_ID=
BELBERRY_BITRIX24_GOOGLE_DRIVE_FOLDER_ID=

# Bitrix24 webhook техпользователя.
# Реальный URL не коммитить и не печатать в логах.
BELBERRY_BITRIX24_WEBHOOK_URL=

# OAuth local app, если webhook недостаточен.
BELBERRY_BITRIX24_CLIENT_ID=
BELBERRY_BITRIX24_CLIENT_SECRET=
BELBERRY_BITRIX24_APP_STATE_DIR=belberry/bitrix24/state/bitrix-oauth

# Режим безопасности для первых прогонов.
BELBERRY_BITRIX24_DRY_RUN=true
BELBERRY_BITRIX24_TIMEZONE=Europe/Moscow
