# Belberry Bitrix24 duplicate merge isolated runtime
# Реальный файл `.env` не коммитится.
# Перед первым запуском: python3 -m pip install -r belberry/bitrix24/requirements.txt --user

BELBERRY_BITRIX24_TIMEZONE=Europe/Moscow
BELBERRY_BITRIX24_PORTAL_BASE_URL=https://belberrycrm.bitrix24.ru

# Safety gate: apply запрещен, пока значение не равно explicit.
BELBERRY_BITRIX24_DEFAULT_MODE=dry-run
BELBERRY_BITRIX24_REQUIRE_APPLY_CONFIRMATION=true
BELBERRY_BITRIX24_PROCESS_LOCK_PATH=belberry/bitrix24/state/duplicate-merge.lock
BELBERRY_BITRIX24_LEDGER_PATH=belberry/bitrix24/state/duplicate-merge-ledger.jsonl

# Google Sheets.
BELBERRY_BITRIX24_DUPLICATES_SHEET_ID=<google_sheet_id>
# Реальный ID хранится только в локальном .env, не в example.
BELBERRY_BITRIX24_DUPLICATES_WORK_SHEET=Дубли Реанимация
BELBERRY_BITRIX24_DUPLICATES_ARCHIVE_SHEET=Объединено
BELBERRY_BITRIX24_DUPLICATES_SOURCE_SHEET=Дубликаты 2
BELBERRY_BITRIX24_GOOGLE_SERVICE_ACCOUNT_JSON=belberry/bitrix24/config/google-service-account.json

# Bitrix OAuth local app.
BELBERRY_BITRIX24_CLIENT_ID=
BELBERRY_BITRIX24_CLIENT_SECRET=
BELBERRY_BITRIX24_APP_STATE_DIR=belberry/bitrix24/state/bitrix-oauth
BELBERRY_BITRIX24_APP_INSTALL_STATE_FILE=
BELBERRY_BITRIX24_OAUTH_TOKEN_URL=
BELBERRY_BITRIX24_TIMEOUT_SEC=20

# Batch limits — это пороги high-conflict risk, а не soft-warnings.
# Превышение любого порога останавливает run со статусом manual_review_high_conflict_risk
# и не зовет crm.entity.mergeBatch.
# 0 = строгий запрет: с такими данными merge не выполняется автоматически даже при apply.
BELBERRY_BITRIX24_BATCH_MAX_GROUP_SIZE=2
BELBERRY_BITRIX24_BATCH_MAX_CONTACT_ADDITIONS=0
BELBERRY_BITRIX24_BATCH_MAX_DEAL_UPDATES=2
BELBERRY_BITRIX24_BATCH_MAX_ACTIVITIES=30
BELBERRY_BITRIX24_BATCH_MAX_TIMELINE_COMMENTS=20
BELBERRY_BITRIX24_BATCH_MAX_PRODUCT_SIGNATURES=0
BELBERRY_BITRIX24_REQUEST_PAUSE_SEC=0.35

# Kill switch: блокирует apply на уровне engine без переразвертывания.
# Любое значение кроме false (включая отсутствие) трактуется как enabled-блок.
BELBERRY_BITRIX24_APPLY_DISABLED=true
