# Часовой пояс и формат отчётов
TZ=Europe/Moscow

# Домены
HAPP_DOMAIN=vpn.example.com
SUBSCRIPTION_URL=https://vpn.example.com/subscription/happ.txt

# SSH
SSH_USER=ops
SSH_KEY_PATH=$HOME/.ssh/temp_migration_key
SSH_PORT=22

# Ноды
PRIMARY_HOST=1.2.3.4
RESERVE_HOST=5.6.7.8
PRIMARY_NODE_NAME=happ-main
RESERVE_NODE_NAME=happ-backup

# VPN
VPN_SERVICE=sing-box
VPN_PORT=443
VPN_TRANSPORT=vless-reality

# Subscription
SUBSCRIPTION_SERVICE=happ-subscription
SUBSCRIPTION_PORT=443
SUBSCRIPTION_PATH=/subscription/happ.txt

# TLS
TLS_HOST=vpn.example.com
TLS_MIN_VALID_DAYS=14

# Проверки
HEALTH_REPORT_DIR=reports
