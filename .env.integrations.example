# Обязательные интеграции
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_BASE_URL=https://sentry.io

OPENAI_API_KEY=
PYTHON_BIN=/Library/Developer/CommandLineTools/Library/Frameworks/Python3.framework/Versions/3.9/Resources/Python.app/Contents/MacOS/Python

NOTION_TOKEN=

# Bitrix24 через локальное приложение
BITRIX_APP_STATE_DIR=/opt/openclaw/state/bitrix_app
BITRIX_CLIENT_ID=
BITRIX_CLIENT_SECRET=
# Необязательно: если нужен явный override refresh endpoint
# BITRIX_OAUTH_TOKEN_URL=https://oauth.bitrix24.tech/oauth/token/

# Telegram для боевой отправки напоминаний
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
LARISA_TELEGRAM_CHAT_ID=
# Отдельный Telegram-контур для Sales Copilot / commercial-director.
# Токен локально лучше не хранить: bridge умеет читать его с сервера по SSH.
SALES_TELEGRAM_CHAT_ID=
SALES_TELEGRAM_OWNER_ID=
SALES_TELEGRAM_DM_CHAT_ID=
SALES_WEEKLY_TELEGRAM_CHAT_ID=
SALES_DEPARTMENT_IDS=
SALES_DEPARTMENT_NAMES=Группа продаж Belberry,Группа продаж Acoola Team,Телемаркетинг
# Явный blacklist для служебных/интеграционных аккаунтов, если они видны в Bitrix.
# SALES_EXCLUDED_USER_IDS=123,456
# SALES_EXCLUDED_USER_NAMES=Колтач Интегратор
# SALES_EXCLUDED_USER_MARKERS=интегратор,service account,bot
# SALES_REMOTE_TELEGRAM_BOT_TOKEN_FILE=/root/.openclaw/telegram/commercial-director.bot_token
# SALES_TELEGRAM_API_BASE_URL=https://api.telegram.org
# Дополнительные чаты/группы: alias=chat_id,alias2=chat_id
# TELEGRAM_TARGETS=owner=123456789,larisa-ivanovna=123456789,ops=-1001111111111,team=-1002222222222
# Дополнительный whitelist chat id, если нужен явный контроль
# TELEGRAM_ALLOWED_CHAT_IDS=-1001111111111,-1002222222222
# TELEGRAM_DRY_RUN=1

# WAZZUP / WhatsApp
WAZZUP_API_KEY=
WAZZUP_API_BASE_URL=https://api.wazzup24.com
# Если Bitrix app должен пробрасывать webhook в отдельный endpoint.
WAZZUP_WEBHOOK_FORWARD_URL=
# Необязательно: если health-check должен идти в отдельный endpoint
# WAZZUP_API_CHECK_URL=https://api.wazzup24.com/v3/channels

# WHOOP OAuth
WHOOP_CLIENT_ID=
WHOOP_CLIENT_SECRET=
WHOOP_REFRESH_TOKEN=
WHOOP_REDIRECT_URI=
WHOOP_TOKEN_URL=https://api.prod.whoop.com/oauth/oauth2/token
WHOOP_API_BASE=https://api.prod.whoop.com/developer/v2

# Web Search
SEARCH_PROVIDER=duckduckgo
SEARCH_BASE_URL=
SEARCH_ENGINE=duckduckgo
SEARCH_TIMEOUT_SECONDS=10

# Obsidian vault через GitHub
OBSIDIAN_VAULT_PATH=/srv/cloudbot/obsidian-vault
OBSIDIAN_GIT_REMOTE=git@github.com:USER/cloudbot-obsidian-vault.git
OBSIDIAN_SYNC_ENABLED=true
OBSIDIAN_DEFAULT_INBOX=Inbox
OBSIDIAN_DAILY_DIR=Daily
OBSIDIAN_TIMEZONE=Europe/Moscow
OBSIDIAN_GIT_AUTHOR_NAME=Cloudbot
OBSIDIAN_GIT_AUTHOR_EMAIL=cloudbot@example.local

# Google / Финансист
GOOGLE_SERVICE_ACCOUNT_JSON=

# GitHub CLI обычно авторизуется через `gh auth login`,
# но токен можно хранить и как переменную:
GH_TOKEN=
