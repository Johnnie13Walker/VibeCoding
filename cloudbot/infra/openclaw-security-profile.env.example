# Скопируйте файл на хост в: /opt/openclaw/.env.security_profile
# Все значения интерпретируются в рамках Europe/Moscow.

# Профиль риска:
# 1/HOME_BALANCE, 2/VPS_HARDENED, 3/DEVELOPER_FRIENDLY, 4/кастом (любая строка)
RISK_PROFILE=VPS_HARDENED

# Канал админ-доступа к хосту:
# local | ssh | ssh_tailnet
ACCESS_MODE=ssh_tailnet

# Разрешен ли публичный доступ к панели OpenClaw/Gateway (0/1)
PUBLIC_DASHBOARD_ALLOWED=0

# Статус шифрования диска: enabled | disabled | unknown
DISK_ENCRYPTION_STATUS=unknown

# Политика резервного копирования
BACKUP_REQUIRED=1
BACKUP_MAX_AGE_HOURS=24
BACKUP_PATHS=/var/backups/openclaw,/opt/openclaw/backups,/root/.openclaw/backups

# Обязательные ежедневные проверки
SCHEDULE_SECURITY_AUDIT_DEEP=1
SCHEDULE_UPDATE_STATUS=1
