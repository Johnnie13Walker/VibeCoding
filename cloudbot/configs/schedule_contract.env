# Канонический контракт расписаний Cloudbot/OpenClaw.
# Все выражения помечены часовым поясом в имени переменной.
# Любой workflow, который применяет cron или OpenClaw jobs, должен читать значения отсюда.

# Локальный maintenance-контур
AGENT_COMMIT_CRON_MSK="0 6 * * *"

# Лариса Ивановна
LARISA_DAILY_CRON_MSK="0 8 * * *"
LARISA_EVENING_CRON_MSK="0 19 * * *"
LARISA_DAILY_CRON_EXPR_UTC="0 5 * * *"
LARISA_EVENING_CRON_EXPR_UTC="0 16 * * *"
LARISA_ENABLE_EVENING_CRON="0"

# OpenClaw scheduler jobs
OPENCLAW_HEALTH_CRON_MSK="0 9 * * *"
OPENCLAW_STATUS_CRON_MSK="30 9 * * *"
OPENCLAW_HEALTH_DELIVERY_MODE="none"
OPENCLAW_STATUS_DELIVERY_MODE="announce"

# Sales runtime на Debian cron хранится в UTC
SALES_DAILY_CRON_EXPR_UTC="30 6 * * 1-5"
SALES_CHECK_CRON_EXPR_UTC="40 6 * * 1-5"
SALES_FOLLOWUP_CRON_EXPR_UTC="0 14 * * *"
SALES_WEEKLY_CRON_EXPR_UTC="30 15 * * 5"

# WHOOP server-only cron (UTC)
WHOOP_REPORT_CRON_EXPR_UTC="1 5 * * *"

# Server-only todo-integration cron (UTC)
TODO_DIGEST_MORNING_ENABLED="0"
TODO_DIGEST_MIDDAY_ENABLED="0"
TODO_DIGEST_EVENING_ENABLED="0"
TODO_DIGEST_EVENING_CRON_EXPR_UTC="0 16 * * *"
TODO_REMINDERS_CRON_EXPR_UTC="* * * * *"
TODO_EXECUTION_TICK_CRON_EXPR_UTC="*/15 * * * *"
